        milestones: [
          { name: '系统稳定运行', deadline: new Date(Date.now() + 7 * 24 * 60 * 60 * 1000).toISOString() },
          { name: '目标指标全部达成', deadline: new Date(Date.now() + 30 * 24 * 60 * 60 * 1000).toISOString() }
